rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- Users Collection ---
    match /users/{userId} {
      // SECURITY: Only authenticated users can read user profiles
      // Users can read their own full profile, others can only see public fields
      allow read: if isOwner(userId);
      
      // Only the user can create or update their own profile.
      // Validate that the document ID matches the auth UID.
      allow create: if isOwner(userId) 
                    && (request.auth.token.email != null ? request.resource.data.email == request.auth.token.email : true);
      
      allow update: if isOwner(userId)
                    // If email is being changed, ensure it matches the token (if token has email)
                    && (request.resource.data.email == resource.data.email 
                        || (request.auth.token.email != null && request.resource.data.email == request.auth.token.email));
                            
      allow delete: if isOwner(userId);
    }

    // --- Quotes Collection ---
    match /quotes/{quoteId} {
      // Consolidated read rule for quotes
      // Allow if:
      // 1. Quote is public (defaults to true for legacy/public quotes)
      // 2. OR Quote is a system default
      // 3. OR Quote is owned by system
      // 4. OR User is the owner
      // 5. OR User has this quote in their favorites
      allow read: if isAuthenticated() 
                  && (
                    resource == null ||
                    resource.data.get('isPublic', true) == true || 
                    resource.data.get('isDefault', false) == true || 
                    resource.data.get('userId', '') == 'system' ||
                    resource.data.get('userId', '') == request.auth.uid ||
                    exists(/databases/$(database)/documents/favorites/$(request.auth.uid)/items/$(quoteId))
                  );

      // Create: Authenticated users can create quotes for themselves
      allow create: if isAuthenticated() 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.quoteText is string
                    && request.resource.data.quoteText.size() > 0;

      // Update/Delete: Only the owner can modify, and cannot delete system quotes
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == resource.data.userId;
      
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid
                    && resource.data.get('isDefault', false) != true;
    }

    // --- Categories Collection ---
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    // --- Favorites Collection ---
    // Structure: /favorites/{userId}/items/{quoteId}
    match /favorites/{userId} {
      // Allow user to read/write their own favorites root and sub-collections
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      
      match /items/{quoteId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }
  }
}
